#!name= RuoYi License ExpiresAt Modifier
#!desc= 修改 RuoYi Plus 许可证 API 的 expiresAt 年份为 2029
#!system= ios,macos
#!homepage= https://github.com/your-username/your-repo

[Script]
http-response ^https://license\.ruoyi\.plus/flm/public/client/init script-path = https://raw.githubusercontent.com/vwvve/LSQ/main/script/change-expiresat.js, requires-body = true, type = http-response

[MITM]
hostname = license.ruoyi.plus